# ============================================================
# Environment variables — NEVER commit real secrets
# ============================================================
.env
.env.local
.env.*.local

# ============================================================
# SQLite database files — данные не заливаем, только схему
# ============================================================
*.sqlite
*.sqlite3
*.db

# ============================================================
# Node dependencies
# ============================================================
node_modules/
editor-react/node_modules/
chat-server/node_modules/
tgbot/node_modules/

# ============================================================
# User-uploaded files (фото, документы пользователей)
# ============================================================
uploads/
chat-server/uploads/

# ============================================================
# Build outputs
# ============================================================
dist/
build/
editor-react/dist/

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================================
# OS / IDE
# ============================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/settings.json
.idea/

# ============================================================
# DKIM private keys (публичный ключ можно хранить, приватный — нет)
# ============================================================
backend/dkim/*.pem
backend/dkim/*.key
chat-server/dkim/*.pem
chat-server/dkim/*.key

# ============================================================
# PM2 / process manager
# ============================================================
.pm2/
ecosystem.config.js.local

# ============================================================
# Misc
# ============================================================
*.pem
package-lock.json
